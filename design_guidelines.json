{
  "theme": "Light",
  "archetype": "4 (Swiss & High-Contrast / Corporate B2B)",
  "vibe": "Professional, Corporate, Persuasive, Global, Trustworthy",
  "colors": {
    "primary": "#0f172a",
    "primary_foreground": "#ffffff",
    "secondary": "#0e263d",
    "accent_copper": "#c2410c",
    "accent_emerald": "#059669",
    "background": "#f8fafc",
    "surface": "#ffffff",
    "border": "#e2e8f0",
    "text_main": "#1e293b",
    "text_muted": "#64748b"
  },
  "typography": {
    "heading_font": "Outfit, sans-serif",
    "body_font": "Plus Jakarta Sans, sans-serif",
    "scale": {
      "h1": "text-5xl md:text-6xl tracking-tight font-bold",
      "h2": "text-3xl md:text-4xl tracking-tight font-bold",
      "h3": "text-xl md:text-2xl font-semibold",
      "body": "text-base leading-relaxed",
      "small": "text-sm tracking-wide"
    }
  },
  "spacing_and_layout": {
    "container_padding": "px-6 md:px-12 lg:px-24",
    "section_spacing": "py-20 md:py-32",
    "grid_gap": "gap-8 md:gap-12"
  },
  "components": {
    "navigation": {
      "style": "Sticky, glassmorphism (backdrop-blur-xl bg-white/80), 1px subtle bottom border.",
      "features": ["Logo", "Multi-language toggle (EN/HI)", "Download Brochure Button (Warm Copper)"]
    },
    "hero": {
      "layout": "Full viewport height (min-h-[80vh]), centered content",
      "background": "Image with bg-black/50 overlay",
      "cta": "Primary button in Warm Copper, Secondary button outlined in White"
    },
    "products_grid": {
      "layout": "grid-cols-1 md:grid-cols-2 lg:grid-cols-4 or 5",
      "card_style": "Flat surface, subtle shadow (shadow-sm), hover:-translate-y-1 hover:shadow-lg transition-all. Image aspect ratio 4:3 with object-cover."
    },
    "why_choose_us": {
      "layout": "Bento grid or 3-column layout",
      "icon_style": "Phosphor icons, size 32px, colored in Emerald Green or Warm Copper"
    },
    "contact_form": {
      "layout": "Split layout: Contact info on left, form on right. Surface white with 1px border-border.",
      "inputs": "Shadcn UI inputs. Focus state: ring-2 ring-accent_copper."
    },
    "floating_whatsapp": {
      "position": "fixed bottom-6 right-6 z-50",
      "style": "bg-[#25D366] text-white rounded-full p-4 shadow-lg hover:scale-110 transition-transform"
    }
  },
